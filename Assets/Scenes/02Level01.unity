--- !u!114 &786247253
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 786247252}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u042D\u041C\u0415 \u2014 \u044D\u0442\u043E \u0438\u0433\u0440\u0430-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435 \u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435.
    \u041E\u043D\u0430 \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0430\u0435\u0442
    \u0437\u0430\u0434\u0443\u043C\u0430\u0442\u044C\u0441\u044F \u043E \u0442\u043E\u043C,
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043B\u0438 \u043E\u0431\u0440\u0430\u0437
    \xAB\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E\xBB \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0438 \u043A\u0430\u043A\u0438\u0435 \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u044F
    \u2014 \u044F\u0432\u043D\u044B\u0435 \u0438\u043B\u0438 \u0441\u043A\u0440\u044B\u0442\u044B\u0435
    \u2014 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \u0432\u044B\u0434\u0432\u0438\u0433\u0430\u0435\u0442
    \u043A \u043A\u0430\u0436\u0434\u043E\u043C\u0443 \u0438\u0437 \u043D\u0430\u0441.
    \u0413\u0434\u0435 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442 \u0433\u0440\u0430\u043D\u0438\u0446\u0430
    \u043C\u0435\u0436\u0434\u0443 \u0441\u0430\u043C\u043E\u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0438 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u0445?
    \u041D\u0430\u0441 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u044E\u0442
    \u0438\u043B\u0438 \u043C\u044B \u0441\u0430\u043C\u0438 \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0435\u043C\u0441\u044F
    \u044D\u0442\u0438\u043C \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u044F\u043C?
    \u041D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u043E\u0432\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u044B \u0441\u043B\u044B\u0448\u0438\u043C,
    \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u044E\u0442 \u043D\u0430\u0448\u0443
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C?\r\n\r\n\u042D\u0442\u0430 \u0438\u0433\u0440\u0430
    \u2014 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0437\u0430\u0433\u043B\u044F\u043D\u0443\u0442\u044C
    \u0432\u043D\u0443\u0442\u0440\u044C \u0441\u0435\u0431\u044F \u0438 \u0443\u0432\u0438\u0434\u0435\u0442\u044C,
    \u043A\u0430\u043A \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044F \u043D\u0430 \u043D\u0430\u0448\u0435\u043C
    \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0438, \u0440\u0435\u0448\u0435\u043D\u0438\u044F\u0445
    \u0438 \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u044B."
