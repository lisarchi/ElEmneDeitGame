  messages:
  - "\u041F\u0440\u043E\u0434\u0430\u043C \u0433\u0430\u0440\u0430\u0436. 0543 324
    554"
  - "\u0417\u0434\u0435\u0441\u044C \u043C\u043E\u0433\u043B\u0430 \u0431\u044B\u0442\u044C
    \u0412\u0430\u0448\u0430 \u0440\u0435\u043A\u043B\u0430\u043C\u0430!"
  - "\u041F\u043E\u041D\u043D\u0430\u041A\u043E\u041C\u043B\u042E\u0441\u044C \u0434\u041B\u044F
    \u043E\u0411\u0449\u0435\u041D\u0438\u042F! 0515 554 235"
  - "\u0412\u0441\u0435\u043C \u0445\u043E\u0440\u043E\u0448\u0435\u0433\u043E \u0434\u043D\u044F!"
  - Vsem privet :)
  - "\u041E\u0442\u0440\u0443\u0431\u0438. \u041E\u043F\u0442\u043E\u043C. \u0421\u0430\u043C\u043E\u0432\u044B\u0432\u043E\u0437."
  - "\u041F\u0440\u043E\u0434\u0430\u043C \u043F\u0438\u0430\u043D\u0438\u043D\u043E,
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0435, \u0441\u0430\u043C\u043E\u0432\u044B\u0432\u043E\u0437,
    18 \u044D\u0442\u0430\u0436."
  - "\u041E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0441\u044C, \u043F\u043E\u043A\u0430
    \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430 \u043D\u0435 \u0441\u0442\u0430\u043B\u0430
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439"
  - "\u041A\u0443\u0440\u0441\u044B \u043E\u043B\u0431\u0430\u043D\u0441\u043A\u043E\u0433\u043E"
